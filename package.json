{
  "name": "arccjs",
  "version": "3.0.4",
  "description": "ABI-centric Atomic Transaction Composer for Algorand AVM workflows",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "author": "Nicholas Shellabarger",
  "license": "MIT",
  "keywords": [
    "algorand",
    "avm",
    "abi",
    "transaction",
    "composer",
    "smart-contract",
    "arc200",
    "voi"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/temptemp3/arccjs.git"
  },
  "bugs": {
    "url": "https://github.com/temptemp3/arccjs/issues"
  },
  "homepage": "https://github.com/temptemp3/arccjs#readme",
  "dependencies": {
    "algosdk": "^3.5.2",
    "buffer": "^6.0.3",
    "js-sha512": "^0.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
